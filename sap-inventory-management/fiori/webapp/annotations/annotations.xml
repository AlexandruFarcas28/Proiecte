<?xml version="1.0" encoding="UTF-8"?>
<edmx:Edmx Version="4.0" xmlns:edmx="http://docs.oasis-open.org/odata/ns/edmx">
  <edmx:Reference Uri="https://sap.github.io/odata-vocabularies/vocabularies/Common.xml">
    <edmx:Include Alias="Common" Namespace="com.sap.vocabularies.Common.v1"/>
  </edmx:Reference>
  <edmx:Reference Uri="https://sap.github.io/odata-vocabularies/vocabularies/UI.xml">
    <edmx:Include Alias="UI" Namespace="com.sap.vocabularies.UI.v1"/>
  </edmx:Reference>
  <edmx:Reference Uri="https://sap.github.io/odata-vocabularies/vocabularies/Communication.xml">
    <edmx:Include Alias="Communication" Namespace="com.sap.vocabularies.Communication.v1"/>
  </edmx:Reference>

  <edmx:DataServices>
    <Schema Namespace="local" xmlns="http://docs.oasis-open.org/odata/ns/edm">

      <!-- ═══ STOCK Entity Annotations ═══════════════════════════════════════ -->
      <Annotations Target="ZINV_SRV.Stock">

        <!-- Selection Fields for List Report -->
        <Annotation Term="UI.SelectionFields">
          <Collection>
            <PropertyPath>MaterialId</PropertyPath>
            <PropertyPath>Plant</PropertyPath>
            <PropertyPath>StorageLocation</PropertyPath>
            <PropertyPath>StockType</PropertyPath>
          </Collection>
        </Annotation>

        <!-- List Report Table Columns -->
        <Annotation Term="UI.LineItem">
          <Collection>
            <Record Type="UI.DataField">
              <PropertyValue Property="Value" Path="MaterialId"/>
              <PropertyValue Property="Label" String="Material"/>
            </Record>
            <Record Type="UI.DataField">
              <PropertyValue Property="Value" Path="Plant"/>
            </Record>
            <Record Type="UI.DataField">
              <PropertyValue Property="Value" Path="StorageLocation"/>
              <PropertyValue Property="Label" String="Stor. Location"/>
            </Record>
            <Record Type="UI.DataField">
              <PropertyValue Property="Value" Path="Quantity"/>
            </Record>
            <Record Type="UI.DataField">
              <PropertyValue Property="Value" Path="BaseUom"/>
              <PropertyValue Property="Label" String="UoM"/>
            </Record>
            <Record Type="UI.DataFieldForAnnotation">
              <PropertyValue Property="Target" AnnotationPath="@UI.DataPoint#StockStatus"/>
              <PropertyValue Property="Label" String="Status"/>
            </Record>
            <!-- Custom Action Button: Post Goods Receipt -->
            <Record Type="UI.DataFieldForAction">
              <PropertyValue Property="Action" String="ZINV_SRV.PostGoodsReceipt"/>
              <PropertyValue Property="Label" String="Post GR"/>
            </Record>
            <!-- Custom Action Button: Post Goods Issue -->
            <Record Type="UI.DataFieldForAction">
              <PropertyValue Property="Action" String="ZINV_SRV.PostGoodsIssue"/>
              <PropertyValue Property="Label" String="Post GI"/>
            </Record>
          </Collection>
        </Annotation>

        <!-- Header Info for Object Page -->
        <Annotation Term="UI.HeaderInfo">
          <Record Type="UI.HeaderInfoType">
            <PropertyValue Property="TypeName" String="Stock"/>
            <PropertyValue Property="TypeNamePlural" String="Stock Items"/>
            <PropertyValue Property="Title">
              <Record Type="UI.DataField">
                <PropertyValue Property="Value" Path="MaterialId"/>
              </Record>
            </PropertyValue>
            <PropertyValue Property="Description">
              <Record Type="UI.DataField">
                <PropertyValue Property="Value" Path="StockType"/>
              </Record>
            </PropertyValue>
          </Record>
        </Annotation>

        <!-- KPI Data Points -->
        <Annotation Term="UI.DataPoint" Qualifier="StockStatus">
          <Record Type="UI.DataPointType">
            <PropertyValue Property="Value" Path="Quantity"/>
            <PropertyValue Property="Criticality" Path="StockStatus"/>
            <PropertyValue Property="Title" String="Stock Quantity"/>
          </Record>
        </Annotation>

        <!-- Object Page Facets -->
        <Annotation Term="UI.Facets">
          <Collection>
            <Record Type="UI.ReferenceFacet">
              <PropertyValue Property="ID" String="StockInfo"/>
              <PropertyValue Property="Label" String="Stock Information"/>
              <PropertyValue Property="Target" AnnotationPath="@UI.FieldGroup#StockDetails"/>
            </Record>
            <Record Type="UI.ReferenceFacet">
              <PropertyValue Property="ID" String="MovementHistory"/>
              <PropertyValue Property="Label" String="Movement History"/>
              <PropertyValue Property="Target" AnnotationPath="_Movements/@UI.LineItem"/>
            </Record>
          </Collection>
        </Annotation>

        <!-- Field Groups for Object Page -->
        <Annotation Term="UI.FieldGroup" Qualifier="StockDetails">
          <Record Type="UI.FieldGroupType">
            <PropertyValue Property="Data">
              <Collection>
                <Record Type="UI.DataField">
                  <PropertyValue Property="Value" Path="MaterialId"/>
                  <PropertyValue Property="Label" String="Material ID"/>
                </Record>
                <Record Type="UI.DataField">
                  <PropertyValue Property="Value" Path="Plant"/>
                </Record>
                <Record Type="UI.DataField">
                  <PropertyValue Property="Value" Path="StorageLocation"/>
                  <PropertyValue Property="Label" String="Storage Location"/>
                </Record>
                <Record Type="UI.DataField">
                  <PropertyValue Property="Value" Path="StockType"/>
                  <PropertyValue Property="Label" String="Stock Type"/>
                </Record>
                <Record Type="UI.DataField">
                  <PropertyValue Property="Value" Path="Quantity"/>
                </Record>
                <Record Type="UI.DataField">
                  <PropertyValue Property="Value" Path="BaseUom"/>
                  <PropertyValue Property="Label" String="Unit of Measure"/>
                </Record>
                <Record Type="UI.DataField">
                  <PropertyValue Property="Value" Path="LastCountedAt"/>
                  <PropertyValue Property="Label" String="Last Inventory Count"/>
                </Record>
              </Collection>
            </PropertyValue>
          </Record>
        </Annotation>

      </Annotations>

      <!-- ═══ Movement Entity Annotations ════════════════════════════════════ -->
      <Annotations Target="ZINV_SRV.Movement">

        <Annotation Term="UI.LineItem">
          <Collection>
            <Record Type="UI.DataField">
              <PropertyValue Property="Value" Path="MovementType"/>
              <PropertyValue Property="Label" String="Type"/>
            </Record>
            <Record Type="UI.DataField">
              <PropertyValue Property="Value" Path="MovementDate"/>
              <PropertyValue Property="Label" String="Date"/>
            </Record>
            <Record Type="UI.DataField">
              <PropertyValue Property="Value" Path="Quantity"/>
            </Record>
            <Record Type="UI.DataField">
              <PropertyValue Property="Value" Path="ReferenceDoc"/>
              <PropertyValue Property="Label" String="Reference Doc."/>
            </Record>
            <Record Type="UI.DataField">
              <PropertyValue Property="Value" Path="PostedBy"/>
              <PropertyValue Property="Label" String="Posted By"/>
            </Record>
            <Record Type="UI.DataField">
              <PropertyValue Property="Value" Path="Notes"/>
            </Record>
          </Collection>
        </Annotation>

      </Annotations>

    </Schema>
  </edmx:DataServices>
</edmx:Edmx>

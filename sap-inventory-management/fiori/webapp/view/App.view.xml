<mvc:View
    controllerName="com.company.inventorymanagement.controller.App"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    displayBlock="true">
    <App id="app">
        <pages>
            <Page title="📦 Inventory Management - Stock Overview">
                <content>
                    <Table
                        id="stockTable"
                        items="{stock>/}"
                        mode="SingleSelectMaster"
                        growing="true"
                        growingThreshold="10">
                        <headerToolbar>
                            <OverflowToolbar>
                                <Title text="Stock Items"/>
                                <ToolbarSpacer/>
                                <SearchField
                                    placeholder="Search material..."
                                    search=".onSearch"
                                    width="20rem"/>
                            </OverflowToolbar>
                        </headerToolbar>
                        <columns>
                            <Column><Text text="Material ID"/></Column>
                            <Column><Text text="Plant"/></Column>
                            <Column><Text text="Storage Loc."/></Column>
                            <Column><Text text="Stock Type"/></Column>
                            <Column hAlign="End"><Text text="Quantity"/></Column>
                            <Column><Text text="UoM"/></Column>
                            <Column><Text text="Status"/></Column>
                        </columns>
                        <items>
                            <ColumnListItem press=".onStockItemPress" type="Navigation">
                                <cells>
                                    <ObjectIdentifier title="{stock>MaterialId}"/>
                                    <Text text="{stock>Plant}"/>
                                    <Text text="{stock>StorageLocation}"/>
                                    <ObjectStatus
                                        text="{stock>StockType}"
                                        state="{= ${stock>StockType} === 'UN' ? 'Success' : ${stock>StockType} === 'QI' ? 'Warning' : 'Error'}"/>
                                    <ObjectNumber
                                        number="{stock>Quantity}"
                                        state="{= ${stock>Quantity} === 0 ? 'Error' : ${stock>Quantity} &lt; 10 ? 'Warning' : 'Success'}"/>
                                    <Text text="{stock>BaseUom}"/>
                                    <ObjectStatus
                                        text="{= ${stock>StockStatus} === 'S' ? 'In Stock' : 'Empty'}"
                                        state="{= ${stock>StockStatus} === 'S' ? 'Success' : 'Error'}"
                                        icon="{= ${stock>StockStatus} === 'S' ? 'sap-icon://accept' : 'sap-icon://alert'}"/>
                                </cells>
                            </ColumnListItem>
                        </items>
                    </Table>
                </content>
                <footer>
                    <OverflowToolbar>
                        <ToolbarSpacer/>
                        <Button
                            text="Post Goods Receipt"
                            type="Emphasized"
                            icon="sap-icon://add"
                            press=".onPostGR"/>
                        <Button
                            text="Post Goods Issue"
                            type="Default"
                            icon="sap-icon://remove"
                            press=".onPostGI"/>
                    </OverflowToolbar>
                </footer>
            </Page>
        </pages>
    </App>
</mvc:View>

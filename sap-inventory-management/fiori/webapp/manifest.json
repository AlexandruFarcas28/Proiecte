{
  "_version": "1.65.0",
  "sap.app": {
    "id": "com.company.inventorymanagement",
    "type": "application",
    "title": "Inventory Management",
    "applicationVersion": { "version": "1.0.0" }
  },
  "sap.ui": {
    "technology": "UI5",
    "deviceTypes": { "desktop": true, "tablet": true, "phone": true }
  },
  "sap.ui5": {
    "rootView": {
      "viewName": "com.company.inventorymanagement.view.App",
      "type": "XML",
      "async": false,
      "id": "app"
    },
    "dependencies": {
      "minUI5Version": "1.120.0",
      "libs": { "sap.m": {}, "sap.ui.core": {} }
    },
    "models": {
      "stock": {
        "type": "sap.ui.model.json.JSONModel",
        "uri": "localService/mockdata/Stock.json"
      },
      "movements": {
        "type": "sap.ui.model.json.JSONModel",
        "uri": "localService/mockdata/Movement.json"
      }
    }
  }
}
